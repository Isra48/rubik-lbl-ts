{
  "name": "rubik-lbl-ts",
  "version": "0.1.0",
  "description": "Zero-dependency Rubik's Cube toolkit in pure TypeScript: a from-scratch Layer-by-Layer (beginner) solver, sticker color matching, a geometry-derived move engine, and a solvability validator.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && npm run build && node --test \"dist/__tests__/*.test.js\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rubik",
    "rubiks-cube",
    "cube",
    "solver",
    "layer-by-layer",
    "lbl",
    "beginner-method",
    "speedcubing",
    "ida-star",
    "pattern-database",
    "color-detection",
    "computer-vision",
    "typescript",
    "zero-dependency"
  ],
  "author": "Isra48",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Isra48/rubik-lbl-ts.git"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0"
  }
}
